{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "include-component-in-tag": false,
  "packages": {
    "crates/codemem-core": {
      "component": "codemem-core"
    },
    "crates/codemem-storage": {
      "component": "codemem-storage"
    },
    "crates/codemem-embeddings": {
      "component": "codemem-embeddings"
    },
    "crates/codemem-engine": {
      "component": "codemem-engine"
    },
    "crates/codemem": {
      "component": "codemem"
    }
  },
  "plugins": [
    {
      "type": "cargo-workspace"
    },
    {
      "type": "linked-versions",
      "groupName": "codemem",
      "components": [
        "codemem-core",
        "codemem-storage",
        "codemem-embeddings",
        "codemem-engine",
        "codemem"
      ]
    }
  ]
}
